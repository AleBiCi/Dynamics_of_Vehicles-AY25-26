<Group hide-input="false" labelreference="L19851" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">print_procedure(&quot;Implement the Magic formula&quot;,
                &quot;magic_formula&quot;,
                [x,B,C,D,E,SV],
                [mf_res],
                &quot;&quot;,    <Font foreground="[153,51,102]"># no precode</Font>
                code,
                outdir = &quot;./&quot;,
                outfile= true
);</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">% Implement the Magic formula
function [mf_res] = magic_formula(x, B, C, D, E, SV)

 % precode

  

 % main code

  t1 = B .* x;
  t2 = atan(t1);
  t6 = atan(-t1 + (t1 - t2) .* E);
  t8 = sin(t6 .* C);
  mf_res = -t8 .* D + SV;
  
 end

</Text-field>
</Output>
