<Group labelreference="L19796" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal" bullet="dot"><Font bold="true">MF96_FX0_coeffs</Font>:              list of calculated coefficients</Text-field><Text-field style="Text" layout="Normal" bullet="dot"><Font bold="true">MF96_FX0_pars</Font>:                 list of given constant parameters</Text-field><Text-field style="Text" layout="Normal" bullet="dot"><Font bold="true">MF96_FX0_lmabda_pars</Font>:   list of scaling parameters</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L19789" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">tmp1 := indets(MF96_FX0_coeffs_eqns,symbol):                    <Font foreground="[153,51,102]"># extract all symbols in the equation list</Font>
MF96_FX0_coeffs := convert(map(lhs,MF96_FX0_coeffs_eqns),set):  <Font foreground="[153,51,102]"># extract all left hand side parameters</Font>
tmp2            := MF_vars union % :                            <Font foreground="[153,51,102]"># define all known or calculated parameters</Font> 
MF96_FX0_pars   := convert(tmp1 minus tmp2,list):

MF96_FX0_pars,MF96_FX0_lambda_pars := extract_lambda_pars(MF96_FX0_pars):
&lt;op(MF96_FX0_coeffs)&gt;,&lt;MF96_FX0_pars&gt;, &lt;MF96_FX0_lambda_pars&gt;;




</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
