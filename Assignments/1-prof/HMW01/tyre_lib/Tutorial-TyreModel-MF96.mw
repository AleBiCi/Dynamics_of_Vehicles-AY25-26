<Group labelreference="L240986" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Heading 3" layout="Heading 3">Combine lateral+longitudinal force coefficients</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L240985" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">code     := CodeGeneration[Matlab](MF96_FXFYCOMB_coeffs_eqns, resultname='mf_res', optimize = false,output=string);

<Font encoding="UTF-8">map(x-&gt;sprintf(&quot;%-15s = tyre_data.%s;\134n&quot;,convert(x,string)</Font>,convert(x,string)),MF96_FXFYCOMB_pars):
