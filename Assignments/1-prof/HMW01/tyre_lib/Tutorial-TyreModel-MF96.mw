<Section collapsed="false" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 2" layout="Heading 2">Pure longitudinal force</Text-field></Title>
<Group labelreference="L19788" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Pure longitudinal force coefficients:</Text-field>
</Input>
</Group>
<Group labelreference="L19889" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Light blue colored coefficients are constant parameters to be optimised.
Yellow colored parts are variables related functions
Green colored part are scaling coefficients.</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L19785" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">MF96_FX0_coeffs_eqns := [
  
<Font opaque="true" background="[204,255,255]">  common_pars,
</Font>
  <Font foreground="[255,102,0]">#&gt;&gt; pure longitudinal force</Font><Font foreground="[128,128,128]">
</Font>  SHx      = (<Font foreground="[0,204,255]">pHx1</Font>+<Font foreground="[0,204,255]">pHx2</Font>*<Font foreground="[255,204,0]">dfz</Font>)*<Font foreground="[128,128,0]">LHX</Font>,
  SVx      = <Font foreground="[255,204,0]">Fz</Font>*(<Font foreground="[0,204,255]">pVx1</Font>+<Font foreground="[0,204,255]">pVx2</Font>*<Font foreground="[255,204,0]">dfz</Font>)*<Font foreground="[128,128,0]">LVX*LMUX</Font>,
  gamma__s = <Font foreground="[255,204,0]">gamma__w</Font>*<Font foreground="[128,128,0]">LGAMMAY</Font>,
  <Font foreground="[128,128,128]"># equivalent slip</Font>
  kappa__x = <Font foreground="[255,204,0]">kappa</Font>+SHx,
  <Font foreground="[128,128,128]"># coefficients MF</Font><Font foreground="[51,102,255]">
</Font>  Cx    = <Font foreground="[0,204,255]">pCx1</Font>*<Font foreground="[128,128,0]">LCX</Font>,  <Font foreground="[128,128,128]"># </Font><Font foreground="[255,0,0]">must be &gt;0</Font>
  mu__x = (<Font foreground="[0,204,255]">pDx1</Font>+<Font foreground="[0,204,255]">pDx2</Font>*<Font foreground="[255,204,0]">dfz</Font>)*<Font opaque="true" background="[255,255,153]">(1-<Font foreground="[0,204,255]">pDx3</Font>*(gamma__s)^2)*<Font foreground="[128,128,0]">LMUX</Font></Font>, <Font foreground="[128,128,128]"># </Font><Font foreground="[255,0,0]">must be &gt;0</Font>   <Font opaque="true" background="[255,255,153]" foreground="[153,51,102]"># yellow part not in MF96</Font>
  Dx    = mu__x*<Font foreground="[255,204,0]">Fz</Font>, <Font foreground="[128,128,128]"># </Font><Font foreground="[255,0,0]">must be &gt;0</Font><Font foreground="[128,128,128]">
</Font>  Kxk   = <Font foreground="[255,204,0]">Fz</Font>*(<Font foreground="[0,204,255]">pKx1</Font>+<Font foreground="[0,204,255]">pKx2</Font>*<Font foreground="[255,204,0]">dfz</Font>)*exp(<Font foreground="[255,0,0]">-</Font><Font foreground="[0,204,255]">pKx3</Font>*<Font foreground="[255,204,0]">dfz</Font>)*<Font foreground="[128,128,0]">LKXK</Font>, <Font foreground="[128,128,128]">#=Bx*Cx*Dx = diff(Fxo,Kx) at Kx=0 =CFk</Font>
  Bx    = Kxk/(Cx*Dx),
  Ex    = (<Font foreground="[0,204,255]">pEx1+pEx2</Font>*<Font foreground="[255,204,0]">dfz</Font>+<Font foreground="[0,204,255]">pEx3</Font>*<Font foreground="[255,204,0]">dfz</Font>^2)*(1-<Font foreground="[0,204,255]">pEx4</Font>*<Font foreground="[255,102,0]">sign__reg</Font>(kappa__x))*<Font foreground="[128,128,0]">LEX</Font>  <Font foreground="[128,128,128]"># </Font><Font foreground="[255,0,0]">must be &lt;= 1
</Font>]: &lt;%&gt;;

</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group labelreference="L19795" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L240943" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Heading 3" layout="Heading 3">Extract list of parameters:</Text-field>
</Input>
