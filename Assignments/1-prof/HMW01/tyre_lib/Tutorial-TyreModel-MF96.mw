<Section collapsed="false" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 2" layout="Heading 2">Combined longitudinal and lateral forces</Text-field></Title>
<Group labelreference="L19832" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Pure longitudinal force coefficients:
</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L19838" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">MF96_FXFYCOMB_coeffs_eqns := [

<Font opaque="true" background="[204,255,255]">  common_pars,


</Font>  <Font foreground="[255,102,0]">#&gt;&gt; combined forces 
</Font>  <Font foreground="[128,128,128]"># longitudinal</Font><Font foreground="[51,102,255]"> </Font>
  SHxa = <Font foreground="[0,204,255]">rHx1</Font>,
  Bxa  = <Font foreground="[0,204,255]">rBx1</Font>*cos(arctan(<Font foreground="[0,204,255]">rBx2</Font>*<Font foreground="[255,204,0]">kappa</Font>))*<Font foreground="[128,128,0]">LXA</Font>, <Font foreground="[255,0,0]"># must be  &gt;0</Font>
  Cxa  = <Font foreground="[0,204,255]">rCx1</Font>, <Font foreground="[255,0,0]"># must be  &gt;0</Font>
  Dxa  = 1/(cos(Cxa*arctan(Bxa*SHxa))),
  Gxa  = Dxa*cos(Cxa*arctan(Bxa*(<Font foreground="[255,204,0]">alpha</Font>+SHxa))),
  <Font foreground="[128,128,128]"># lateral</Font><Font foreground="[51,102,255]"> </Font>
  SHyk = <Font foreground="[0,204,255]">rHy1</Font>,  <Font foreground="[255,0,0]"># must be  &lt; 0.1 (drive slip)</Font>
  DVyk = mu__y*<Font foreground="[255,204,0]">Fz</Font>*(<Font foreground="[0,204,255]">rVy1</Font>+<Font foreground="[0,204,255]">rVy2</Font>*<Font foreground="[255,204,0]">dfz</Font>+<Font foreground="[0,204,255]">rVy3</Font>*<Font foreground="[255,204,0]">gamma__w</Font>)*cos(arctan(<Font foreground="[0,204,255]">rVy4</Font>*<Font foreground="[255,204,0]">alpha</Font>)),
  SVyk = DVyk*sin(<Font foreground="[0,204,255]">rVy5</Font>*arctan(<Font foreground="[0,204,255]">rVy6</Font>*<Font foreground="[255,204,0]">kappa</Font>))*<Font foreground="[128,128,0]">LVYK</Font>,
  Byk  = <Font foreground="[0,204,255]">rBy1</Font>*cos(arctan(<Font foreground="[0,204,255]">rBy2</Font>*(<Font foreground="[255,204,0]">alpha</Font>-<Font foreground="[0,204,255]">rBy3</Font>)))*<Font foreground="[128,128,0]">LYK</Font>, <Font foreground="[255,0,0]"># must be  &gt;0</Font>
  Cyk  = rCy1,<Font foreground="[255,0,0]"># must be  &gt;0</Font>
  Dyk  = 1/(cos(Cyk*arctan(Byk*SHyk))),
  Gyk  = Dyk*cos(Cyk*arctan(Byk*(<Font foreground="[255,204,0]">kappa</Font>+SHyk))) 

]: &lt;%&gt;;

</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
