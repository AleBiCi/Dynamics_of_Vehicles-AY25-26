</Group>
<Group hide-input="false" labelreference="L19821" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">MF96_MZ0_coeffs_eqns := [

<Font opaque="true" background="[204,255,255]">  common_pars,


</Font>  <Font foreground="[255,102,0]">#&gt;&gt; pure aligning torque</Font>  
  <Font foreground="[128,128,128]"># equivalent slips</Font><Font foreground="[51,102,255]">
  </Font><Font foreground="[255,153,204]">gamma__z</Font> = <Font foreground="[255,204,0]">gamma__w</Font>*<Font foreground="[128,128,0]">LGAMMAY</Font>,
  SHf      = SHy+SVy/Kya,
  SHt      = <Font foreground="[0,204,255]">qHz1</Font>+<Font foreground="[0,204,255]">qHz2</Font>*<Font foreground="[255,204,0]">dfz</Font>+(<Font foreground="[0,204,255]">qHz3</Font>+<Font foreground="[0,204,255]">qHz4</Font>*<Font foreground="[255,204,0]">dfz</Font>)*<Font foreground="[255,153,204]">gamma__z</Font>,
  alpha__t = alpha+SHt,
  alpha__r = alpha+SHf,
  <Font foreground="[128,128,128]"># coefficients MF</Font><Font foreground="[51,102,255]">
 </Font> Bt      = (<Font foreground="[0,204,255]">qBz1</Font>+<Font foreground="[0,204,255]">qBz2</Font>*<Font foreground="[255,204,0]">dfz</Font>+<Font foreground="[0,204,255]">qBz3</Font>*<Font foreground="[255,204,0]">dfz</Font>^2)*(1+<Font foreground="[0,204,255]">qBz4</Font>*<Font foreground="[255,153,204]">gamma__z</Font>+<Font foreground="[0,204,255]">qBz5</Font>*abs__reg(<Font foreground="[255,153,204]">gamma__z</Font>))*<Font foreground="[128,128,0]">LKY</Font>/<Font foreground="[128,128,0]">LMUY</Font>,
  Ct      = qCz1, <Font foreground="[255,0,0]"># must be &gt; 0</Font>
  Dt      = <Font foreground="[255,204,0]">Fz</Font>*(<Font foreground="[0,204,255]">qDz1</Font>+<Font foreground="[0,204,255]">qDz2</Font>*<Font foreground="[255,204,0]">dfz</Font>)*(1+<Font foreground="[0,204,255]">qDz3</Font>*<Font foreground="[255,153,204]">gamma__z</Font>+<Font foreground="[0,204,255]">qDz4</Font>*<Font foreground="[255,153,204]">gamma__z</Font>^2)*R0/Fz0*<Font foreground="[128,128,0]">LT</Font>,
  Et      = (<Font foreground="[0,204,255]">qEz1</Font>+<Font foreground="[0,204,255]">qEz2</Font>*<Font foreground="[255,204,0]">dfz</Font>+<Font foreground="[0,204,255]">qEz3</Font>*<Font foreground="[255,204,0]">dfz</Font>^2)*(1+(<Font foreground="[0,204,255]">qEz4</Font>+<Font foreground="[0,204,255]">qEz5</Font>*<Font foreground="[255,153,204]">gamma__z</Font>)*arctan(Bt*Ct*alpha__t)), <Font foreground="[255,0,0]"># must be &lt;=1</Font>
  Br      = (<Font foreground="[0,204,255]">qBz9</Font>*<Font foreground="[128,128,0]">LKY</Font>/<Font foreground="[128,128,0]">LMUY</Font>+<Font foreground="[0,204,255]">qBz10</Font>*By*Cy),
  Dr      = <Font foreground="[255,204,0]">Fz</Font>*(<Font foreground="[0,204,255]">qDz6</Font>+<Font foreground="[0,204,255]">qDz7</Font>*<Font foreground="[255,204,0]">dfz</Font>+(<Font foreground="[0,204,255]">qDz8</Font>+<Font foreground="[0,204,255]">qDz9</Font>*<Font foreground="[255,204,0]">dfz</Font>)*<Font foreground="[255,153,204]">gamma__z</Font>)*R0*<Font foreground="[128,128,0]">LMUY</Font>*<Font foreground="[128,128,0]">LMR</Font>
]: &lt;%&gt;;

</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
