</Font>  <Font foreground="[255,102,0]">#&gt;&gt; pure lateral force</Font><Font foreground="[0,0,255]">
  </Font>gamma__s = <Font foreground="[255,204,0]">gamma__w</Font>*<Font foreground="[128,128,0]">LGAMMAY</Font>,
  SHy      = (<Font foreground="[0,204,255]">pHy1</Font>+<Font foreground="[0,204,255]">pHy2</Font>*<Font foreground="[255,204,0]">dfz</Font>+<Font foreground="[0,204,255]">pHy3</Font>*<Font foreground="[255,102,0]">gamma__s</Font>)*<Font foreground="[128,128,0]">LHY</Font>, <Font foreground="[128,128,128]">#+(Kyg0*gamma__s+SVyg)/(Kya+espilon__K)</Font>,
  SVy      = <Font foreground="[255,204,0]">Fz</Font>*(<Font foreground="[0,204,255]">pVy1</Font>+<Font foreground="[0,204,255]">pVy2</Font>*<Font foreground="[255,204,0]">dfz</Font>+(<Font foreground="[0,204,255]">pVy3</Font>+<Font foreground="[0,204,255]">pVy4</Font>*<Font foreground="[255,204,0]">dfz</Font>)*<Font foreground="[255,102,0]">gamma__s</Font>)*<Font foreground="[128,128,0]">LVY</Font>*<Font foreground="[128,128,0]">LMUY</Font>,
  <Font foreground="[128,128,128]"># equivalent slips
</Font>  alpha__y = <Font foreground="[255,204,0]">alpha</Font>+SHy,
  <Font foreground="[128,128,128]"># coefficients MF</Font><Font foreground="[51,102,255]">
</Font>  Cy       = <Font foreground="[0,204,255]">pCy1</Font>*<Font foreground="[128,128,0]">LCY</Font>,<Font foreground="[255,0,0]"># must be &gt;0</Font>
  mu__y    = (<Font foreground="[0,204,255]">pDy1</Font>+<Font foreground="[0,204,255]">pDy2</Font>*<Font foreground="[255,204,0]">dfz</Font>)*(1-<Font foreground="[0,204,255]">pDy3</Font>*<Font foreground="[255,102,0]">gamma__s</Font>^2)*<Font foreground="[128,128,0]">LMUY</Font>,
  Dy       = mu__y*<Font foreground="[255,204,0]">Fz</Font>, <Font foreground="[255,0,0]"># must be &gt;0
</Font>  Ey       = (<Font foreground="[0,204,255]">pEy1</Font>+<Font foreground="[0,204,255]">pEy2</Font>*<Font foreground="[255,204,0]">dfz</Font>)*(1-(<Font foreground="[0,204,255]">pEy3</Font>+<Font foreground="[0,204,255]">pEy4</Font>*<Font foreground="[255,102,0]">gamma__s</Font>)*<Font foreground="[255,0,255]">sign__reg</Font>(alpha__y))*<Font foreground="[128,128,0]">LEY</Font>,  <Font foreground="[255,0,0]"># must be &lt;= 1
</Font>  Kya      = Fz01*<Font foreground="[0,204,255]">pKy1</Font>*sin(2*arctan(<Font foreground="[255,204,0]">Fz</Font>/Fz01/<Font foreground="[0,204,255]">pKy2</Font>))*(1-<Font foreground="[0,204,255]">pKy3</Font>*<Font foreground="[255,0,255]">abs__reg</Font>(<Font foreground="[255,102,0]">gamma__s</Font>))*<Font foreground="[128,128,0]">LFZ0</Font>*<Font foreground="[128,128,0]">LKA,</Font>
            <Font foreground="[128,128,128]">#=By*Cy*Dy = diff(Fyo,alpha) at alpha=0 =CFk</Font>
  By       = Kya/(Cy*Dy)
]: &lt;%&gt;;

</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
