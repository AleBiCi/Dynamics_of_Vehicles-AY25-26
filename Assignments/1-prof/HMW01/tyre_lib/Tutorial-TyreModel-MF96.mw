<Output><Text-field style="Line Printed Output" layout="Line Printed Output">% Coefficients for Magic Formula combined lateral+longitudinal forces
function [Gxa, Gyk, SVyk] = MF96_FXFYCOMB_coeffs(kappa, alpha, gamma__w, Fz, tyre_data)

 % precode

  rBx1            = tyre_data.rBx1;
  rBx2            = tyre_data.rBx2;
  rBy1            = tyre_data.rBy1;
  rBy2            = tyre_data.rBy2;
  rBy3            = tyre_data.rBy3;
  rCx1            = tyre_data.rCx1;
  rCy1            = tyre_data.rCy1;
  rHx1            = tyre_data.rHx1;
  rHy1            = tyre_data.rHy1;
  rVy1            = tyre_data.rVy1;
  rVy2            = tyre_data.rVy2;
  rVy3            = tyre_data.rVy3;
  rVy4            = tyre_data.rVy4;
  rVy5            = tyre_data.rVy5;
  rVy6            = tyre_data.rVy6;
  LFZ0            = tyre_data.LFZ0;
  LVYK            = tyre_data.LVYK;
  LXA             = tyre_data.LXA;
  LYK             = tyre_data.LYK;
  

 % main code

  FZ01 = (LFZ0 .* FZ0);
  dfz = Fz ./ FZ01 - 1;
  SHxa = rHx1;
  Bxa = rBx1 .* (rBx2 .^ 2 .* kappa .^ 2 + 1) .^ (-0.1e1 ./ 0.2e1) .* LXA;
  Cxa = rCx1;
  Dxa = 0.1e1 ./ cos(Cxa .* atan((Bxa .* SHxa)));
  Gxa = Dxa .* cos(Cxa .* atan((Bxa .* (alpha + SHxa))));
  SHyk = rHy1;
  DVyk = mu__y .* Fz .* (rVy2 .* dfz + rVy3 .* gamma__w + rVy1) .* (rVy4 .^ 2 .* alpha .^ 2 + 1) .^ (-0.1e1 ./ 0.2e1);
  SVyk = DVyk .* sin(rVy5 .* atan((rVy6 .* kappa))) .* LVYK;
  Byk = rBy1 .* (1 + rBy2 .^ 2 .* (alpha - rBy3) .^ 2) .^ (-0.1e1 ./ 0.2e1) .* LYK;
  Cyk = rCy1;
  Dyk = 0.1e1 ./ cos(Cyk .* atan((Byk .* SHyk)));
  Gyk = Dyk .* cos(Cyk .* atan((Byk .* (kappa + SHyk))));
  
 end

</Text-field>
</Output>
