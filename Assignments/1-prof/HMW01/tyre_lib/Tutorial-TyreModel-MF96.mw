<Section collapsed="false" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 2" layout="Heading 2">Auxiliary procedure to generate Matlab code</Text-field></Title>
<Group labelreference="L19856" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Procedure to convert a list of symbols into a list of strings</Text-field>
</Input>
</Group>
<Group labelreference="L19855" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">convert_list_to_string := proc(L::list(symbol),$)

  local tmp, i :
  tmp := &quot;&quot;:
  for i from 1 to nops(L)-1 do
    tmp := cat(tmp,convert(L[i],string), &quot;, &quot;);
  end:
  tmp := cat(tmp,convert(L[-1],string));

end:</Text-field>
</Input>
</Group>
<Group labelreference="L19850" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Heading 3" layout="Heading 3">

Procedure to print generated code</Text-field>
</Input>
</Group>
<Group labelreference="L19892" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font bold="true">comment</Font>:        string of comment printed in the matlab file,         
<Font bold="true">fnc_name</Font>:       (string) function name
<Font bold="true">in_args</Font>:            list of input arguments
<Font bold="true">out_args</Font>:         list of output arguments
<Font bold="true">code_header</Font>: pre code to be computed before main code 
<Font bold="true">code_body</Font>:    main code 
<Font bold="true">outfile</Font>:           if true prints the output on a file    
<Font bold="true">outdir</Font>:            output directory. The default is &quot;./tyre_lib/&quot;,
<Font bold="true">print_generated_code</Font>: if true print out the generated code.</Text-field>
</Input>
</Group>
<Group labelreference="L19847" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">print_procedure := proc(comment::string,         
                        fnc_name::string, 
                        in_args::list(symbol), 
                        out_args::list(symbol), 
                        code_header::string, 
                        code_body::string,
                        {outfile::boolean:=false,
                         outdir::string:=&quot;./tyre_lib/&quot;,
                         print_generated_code::booblean:=true},
                        $)

  local tmp_s,tmp1,tmp2, res_file, fd ;

  tmp1 := convert_list_to_string(out_args);
  tmp2 := convert_list_to_string(in_args);

  tmp_s := String( 
<Font encoding="UTF-8">      sprintf(&quot;%% %s\134n&quot;, comment),
      sprintf(&quot;function [%s] = %s(%s)\134n&quot;, </Font>tmp1, fnc_name, tmp2),
      sprintf(&quot;<Font encoding="UTF-8">\134n %% precode\134n\134n&quot;),
      sprintf(&quot;%s\134n&quot;,StringTools:-Indent(</Font>code_header,2)),
      s<Font encoding="UTF-8">printf(&quot;\134n %% main code\134n\134n&quot;),
      sprintf(&quot;%s\134n&quot;,</Font>StringTools:-Indent(code_body,2)),
<Font encoding="UTF-8">      sprintf(&quot; end\134n&quot;</Font>)
      ):

 <Font opaque="true" background="[255,255,153]"> # For Matlab vector operation
  tmp_s := StringTools:-Subs(&quot;*&quot;=&quot;.*&quot;,tmp_s);
  tmp_s := StringTools:-Subs(&quot;/&quot;=&quot;./&quot;,tmp_s);
  tmp_s := StringTools:-Subs(&quot;^&quot;=&quot;.^&quot;,tmp_s);
</Font>
  if print_generated_code then 
<Font encoding="UTF-8">    printf(&quot;%s\134n&quot;,</Font>tmp_s);
  end:
  
  if outfile then
    if not(FileTools:-IsDirectory(outdir) ) then 
<Font encoding="UTF-8">      printf(&quot;Creating folder %s\134n&quot;, outdir);
</Font>      FileTools:-MakeDirectory(outdir);
    end:
    res_file := cat(outdir,cat(fnc_name, &quot;.m&quot;)); print(res_file);
    <Font encoding="UTF-8">printf(&quot;Writing output file: %s\134n&quot;,</Font>res_file);
    fd := fopen(res_file, WRITE);
    fprintf(fd, &quot;%s&quot;,tmp_s);
    fclose(fd);
    <Font encoding="UTF-8">printf(&quot;done!\134n&quot;</Font>);
  end:

end proc:</Text-field>
</Input>
</Group>
</Section>
