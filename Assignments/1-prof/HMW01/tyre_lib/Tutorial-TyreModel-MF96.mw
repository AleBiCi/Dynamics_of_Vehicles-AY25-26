header_code:= cat(op(%%),op(%)):

print_procedure(&quot;Coefficients for Magic Formula combined lateral+longitudinal forces&quot;,
                &quot;MF96_FXFYCOMB_coeffs&quot;,
                [kappa,alpha,gamma__w,Fz, <Font opaque="true" background="[204,255,204]">tyre_data</Font>],
                [Gxa, Gyk, SVyk],
                header_code,
                code,
                outdir = &quot;./&quot;,
