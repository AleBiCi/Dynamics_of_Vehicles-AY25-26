<Section collapsed="false" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 1" layout="Heading 1">Description: 1996 Pacejka Tire model</Text-field></Title>
<Group labelreference="L19715" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Required Inputs (Units and Sign Convention)
<Font encoding="UTF-8"> \342\200\242 \316\272: slip ratio (%, i.e. 0.10 = 10%) where a </Font><Font bold="true">+ slip ratio generates a driving force</Font>
<Font encoding="UTF-8">\342\200\242 Fz: normal force (N)
\342\200\242 D\306\222z = (Fz \342\200\223 Fz0)/Fz0
\342\200\242 Fz0 = Nominal Load as defined in Coefficient Tables in Appendix I
\342\200\242 \316\261: slip angle (rad) where a </Font><Font bold="true">+ slip angle generates a positive lateral force</Font>
<Font encoding="UTF-8">\342\200\242 \316\263: camber angle (rad) where a + camber angle indicates the top of the tire tipped right (same sign convention for left and right tires)
\342\200\242 \316\273: multiplier, which should be left at 1.0 for most applications.
</Font></Text-field>
</Input>
</Group>
<Group labelreference="L19714" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Resulting Outputs (Units and Sign Convention)
<Font encoding="UTF-8">\342\200\242 Fy : Lateral Force (N)
\342\200\242 Fx : Longitudinal Force (N)
\342\200\242 Mz : Aligning Torque (N-m)
</Font></Text-field>
</Input>
</Group>
<Group labelreference="L19717" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font foreground="[255,0,0]">NOTE: instead of &quot;gamma&quot; &quot;gamma__w&quot; is used since in Maple &quot;gamma&quot; is a constant 0.57.</Font>.
</Text-field>
</Input>
</Group>
<Group hide-output="false" labelreference="L19716" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font foreground="[255,0,0]">(*lambda__mu__x1 := 1:
  lambda__mu__y1 := 1:
  lambda__Fz0 := 1:
*)</Font></Text-field>
</Input>
</Group>
<Group labelreference="L19798" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Procedure to extract 'lambda__' parameters in a list</Text-field>
</Input>
</Group>
<Group labelreference="L19799" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">extract_lambda_pars := proc(pars_list,$)
  local tmp1, tmp, i;
  tmp1 := StringTools:-SearchAll(&quot;L&quot;,map(convert,pars_list,string));
  tmp := []:
  for i from 1 to nops(tmp1) do:
   if numelems(tmp1[i]) &lt;&gt; 0 then
     tmp:=[op(tmp), pars_list[i]]:
    end:
   end do:
  tmp;
  convert(convert(pars_list,set) minus convert(tmp,set),list), tmp;
end:</Text-field>
</Input>
</Group>
</Section>
