header_code:= cat(op(%%),op(%)):

print_procedure(&quot;Coefficients for Magic Formula pure lateral force&quot;,
                &quot;MF96_FY0_coeffs&quot;,
                [kappa,alpha,gamma__w,Fz, <Font opaque="true" background="[204,255,204]">tyre_data</Font>],
                [alpha__y, By, Cy, Dy, Ey, SVy, Kya],
                header_code,
                code,
                outdir = &quot;./&quot;,
                outfile= true
):
</Text-field>
